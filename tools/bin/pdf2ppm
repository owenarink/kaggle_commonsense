#!/usr/bin/env python3
from __future__ import annotations

import os
import subprocess
import sys


def main() -> int:
    if len(sys.argv) != 2:
        print("usage: pdf2ppm <input.pdf>", file=sys.stderr)
        return 2

    pdf = sys.argv[1]
    cmd = ["pdftoppm", "-singlefile", "-r", "220", pdf]
    proc = subprocess.run(cmd, stdout=sys.stdout.buffer, stderr=sys.stderr.buffer)
    return proc.returncode


if __name__ == "__main__":
    raise SystemExit(main())
