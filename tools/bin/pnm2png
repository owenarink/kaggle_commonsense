#!/usr/bin/env python3
from __future__ import annotations

import io
import sys

from PIL import Image


def main() -> int:
    raw = sys.stdin.buffer.read()
    if not raw:
        return 1
    img = Image.open(io.BytesIO(raw))
    img.save(sys.stdout.buffer, format="PNG")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
